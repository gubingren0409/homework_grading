# Qwen-VL API 配置
# 支持单 Key 或多 Key 池化（逗号分隔）
QWEN_API_KEYS=sk-your-qwen-key-1,sk-your-qwen-key-2
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_NAME=qwen-vl-max
PERCEPTION_PROVIDER=qwen

# DeepSeek API 配置  
# 支持单 Key 或多 Key 池化（逗号分隔）
DEEPSEEK_API_KEYS=sk-your-deepseek-key-1,sk-your-deepseek-key-2,sk-your-deepseek-key-3
DEEPSEEK_MODEL_NAME=deepseek-reasoner
# 是否使用流式输出（建议 false：缓存命中更高、解析更稳定）
DEEPSEEK_USE_STREAM=false
# 紧急止损开关：false 时阻断所有模型外呼（Qwen/DeepSeek）
LLM_EGRESS_ENABLED=true

# Redis 配置 (Phase 28: 消息队列解耦)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# 批量单页模式内部并发（单个 Celery 任务内并发学生数）
BATCH_INTERNAL_CONCURRENCY=3
# 批量后处理（落库+校验）并发
BATCH_POSTPROCESS_CONCURRENCY=4
# 批量进度更新节流：每处理 N 份结果至少更新一次
BATCH_PROGRESS_UPDATE_STEP=2
# 批量进度更新节流：两次更新最小间隔（秒）
BATCH_PROGRESS_MIN_INTERVAL_SECONDS=1.5

# SSE 连接参数（避免被 5s 无数据超时中断）
SSE_STREAM_TIMEOUT_SECONDS=1800
SSE_HEARTBEAT_INTERVAL_SECONDS=3

# 数据库配置（可选）
SQLITE_DB_PATH=outputs/grading_database.db

# 可选外部 Skills（Phase 43，默认关闭）
# 1) 视觉版面解析 Skill（llamaparse / unstructured）
SKILL_LAYOUT_PARSER_ENABLED=false
SKILL_LAYOUT_PARSER_PROVIDER=none
SKILL_LAYOUT_PARSER_API_URL=http://127.0.0.1:8000/api/v1/skills/layout/parse
SKILL_LAYOUT_PARSER_API_KEY=
SKILL_LAYOUT_PARSER_TIMEOUT_SECONDS=20

# 2) 逻辑客观校验 Skill（e2b）
SKILL_VALIDATION_ENABLED=false
SKILL_VALIDATION_PROVIDER=none
SKILL_VALIDATION_API_URL=http://127.0.0.1:8000/api/v1/skills/validate
SKILL_VALIDATION_API_KEY=
SKILL_VALIDATION_TIMEOUT_SECONDS=20
SKILL_VALIDATION_FAIL_OPEN=true

# Skills 网关鉴权（建议生产开启）
SKILL_GATEWAY_AUTH_ENABLED=false
SKILL_GATEWAY_AUTH_TOKEN=

# Prompt token 预算（Phase C，默认放宽以支持多页/多图 rubric 生成）
PROMPT_MAX_INPUT_TOKENS=32768
PROMPT_RESERVE_OUTPUT_TOKENS=1024

# Runtime Router / Auto Circuit（Phase B）
AUTO_CIRCUIT_CONTROLLER_ENABLED=true
AUTO_CIRCUIT_FAILURE_RATE_THRESHOLD=0.30
AUTO_CIRCUIT_TOKEN_SPIKE_THRESHOLD=1.80
AUTO_CIRCUIT_MIN_SAMPLES=20
ROUTER_BUDGET_TOKEN_LIMIT=9000

# Phase E1：分环境配置与特性开关
DEPLOYMENT_ENVIRONMENT=dev
FEATURE_FLAG_PROVIDER_SWITCH=true
FEATURE_FLAG_PROMPT_CONTROL=true
FEATURE_FLAG_ROUTER_CONTROL=true

# 日志级别（可选）
# LOG_LEVEL=INFO
